# Copy to .env and fill in your own values. NEVER commit the real .env.

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# SendGrid — https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
FROM_EMAIL=you@example.com

# Serper (web search) — https://serper.dev
SERPER_API_KEY=

# Reddit app — https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=easemailing/1.0 by your_username

# Flask
FLASK_DEBUG=false
PORT=5000
