# Copy to backend/.env (it's gitignored — never commit it).

# --- AI engine ---------------------------------------------------------------
# With a key, emails are analyzed by Claude. Without one, the app still works
# end-to-end using a built-in heuristic (demo mode).
# ANTHROPIC_API_KEY=sk-ant-...
# AIEA_MODEL=claude-opus-4-8        # or claude-haiku-4-5 for cheaper/faster

# --- Inbox source ------------------------------------------------------------
# demo (default) = built-in mock inbox; live = real Gmail (requires OAuth below)
# AIEA_MODE=demo

# --- Live Gmail (only needed when AIEA_MODE=live) ----------------------------
# Download an OAuth client secret (Desktop app) from Google Cloud Console.
# GMAIL_CREDENTIALS=/absolute/path/to/credentials.json
# GMAIL_TOKEN=/absolute/path/to/token.json   # auto-created after first auth

# --- Frontend ----------------------------------------------------------------
# The Vite app reads this; defaults to http://localhost:8000 if unset.
# Set in frontend/.env as: VITE_API_BASE=http://localhost:8000
